{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [ { "source": "**/*.@(html)", "headers": [ { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" } ] } ], "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
